{
  "name": "rqst",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.7.0",
  "workspaces": [
    "mobile",
    "desktop",
    "admin_dashboard",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node scripts/fix-react-native-maps-marker.js",
    "dev": "pnpm --parallel --filter @rqst/mobile --filter @rqst/desktop dev",
    "dev:mobile": "pnpm --filter @rqst/mobile dev",
    "dev:mobile:clear": "pnpm --filter @rqst/mobile dev:clear",
    "dev:desktop": "pnpm --filter @rqst/desktop dev",
    "dev:admin": "pnpm --filter @rqst/admin-dashboard dev",
    "lint": "pnpm --filter @rqst/mobile lint && pnpm --filter @rqst/desktop lint && pnpm --filter @rqst/admin-dashboard lint",
    "test": "pnpm --filter @rqst/mobile test && pnpm --filter @rqst/desktop test && pnpm --filter @rqst/admin-dashboard test",
    "contracts:generate": "pnpm --filter @rqst/contracts generate",
    "mobile:dev": "pnpm --filter @rqst/mobile dev",
    "mobile:ios": "pnpm --filter @rqst/mobile ios"
  }
}
