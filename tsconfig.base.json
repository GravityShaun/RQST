{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@rqst/contracts": [
        "packages/contracts/src"
      ],
      "@rqst/shared-config": [
        "packages/shared-config/src"
      ]
    }
  }
}

